# Shopify Agent Backend Environment Variables
# IMPORTANT: Never commit a .env file with real values to GitHub!
# This .env.example is just a template showing what variables are needed.
# Set the real values in Railway's Variables tab.

# ========== Shopify ==========
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here
# Leave blank initially - will be set after OAuth completes
SHOPIFY_ACCESS_TOKEN=

# ========== Claude (Anthropic) ==========
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# ========== App URL ==========
# This will be your Railway URL after deployment
APP_URL=https://your-app.railway.app
